{
  "sections": {
    "image_banner": {
      "type": "image-banner",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "心地よさは、いちばんの贅沢。",
            "heading_size": "h0"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "肌に触れる天然素材、流行に流されないデザイン。長く愛せる日常着で、ふつうの毎日を少し豊かに。",
            "text_style": "body"
          }
        },
        "button": {
          "type": "buttons",
          "settings": {
            "button_label_1": "コレクションを見る",
            "button_link_1": "shopify://collections/all",
            "button_style_secondary_1": true,
            "button_label_2": "",
            "button_link_2": "",
            "button_style_secondary_2": false
          }
        }
      },
      "block_order": [
        "heading",
        "text",
        "button"
      ],
      "settings": {
        "image": "shopify://shop_images/komorebi-hero.jpg",
        "image_overlay_opacity": 40,
        "image_height": "large",
        "desktop_content_position": "middle-left",
        "show_text_box": false,
        "desktop_content_alignment": "left",
        "color_scheme": "scheme-3",
        "mobile_content_alignment": "center",
        "stack_images_on_mobile": false,
        "show_text_below": false
      }
    },
    "rich_text": {
      "type": "rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "heading": "Komorebiについて",
            "heading_size": "h1"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>「木漏れ日」のように、やわらかく日常に寄り添うブランドです。リネン・オーガニックコットン・ウールなど、肌になじむ天然素材だけを厳選し、流行に左右されないシンプルなデザインに仕立てています。<\/p><p>大切にしているのは、長く愛せること。着るほどに体になじみ、暮らしに静かな心地よさをもたらす——そんな日常着と暮らしの道具を、ひとつひとつ丁寧にお届けします。<\/p>"
          }
        }
      },
      "block_order": [
        "heading",
        "text"
      ],
      "settings": {
        "color_scheme": "scheme-1",
        "full_width": true,
        "padding_top": 72,
        "padding_bottom": 72
      }
    },
    "featured_collection": {
      "type": "featured-collection",
      "settings": {
        "title": "おすすめ商品",
        "heading_size": "h2",
        "collection": "all",
        "products_to_show": 8,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "show_view_all": false,
        "swipe_on_mobile": false,
        "image_ratio": "square",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 28,
        "padding_bottom": 36
      }
    },
    "komorebi_promise": {
      "type": "komorebi-promise",
      "blocks": {
        "b1": {
          "type": "promise",
          "settings": {
            "icon": "leaf",
            "heading": "上質な天然素材",
            "text": "<p>リネンやオーガニックコットン、ウールなど、肌に心地よい天然素材だけを厳選しています。季節を問わず快適に着られ、使うほどに風合いを増していきます。<\/p>"
          }
        },
        "b2": {
          "type": "promise",
          "settings": {
            "icon": "scissors",
            "heading": "丁寧なものづくり",
            "text": "<p>シンプルなデザインだからこそ、縫製やシルエットの細部まで妥協しません。長く着ても型崩れしにくい、丁寧な仕立てを大切にしています。<\/p>"
          }
        },
        "b3": {
          "type": "promise",
          "settings": {
            "icon": "hanger",
            "heading": "長く使えるデザイン",
            "text": "<p>流行に左右されない、ベーシックで上質なデザイン。何年先も気持ちよく着られる、毎日の定番になる一着をお届けします。<\/p>"
          }
        }
      },
      "block_order": ["b1", "b2", "b3"],
      "settings": {
        "heading": "Komorebiの約束",
        "color_scheme": "scheme-2",
        "padding_top": 64,
        "padding_bottom": 64
      }
    },
    "collection_list": {
      "type": "collection-list",
      "blocks": {
        "tops": { "type": "featured_collection", "settings": { "collection": "トップス" } },
        "bottoms": { "type": "featured_collection", "settings": { "collection": "ボトムス" } },
        "goods": { "type": "featured_collection", "settings": { "collection": "雑貨" } }
      },
      "block_order": ["tops", "bottoms", "goods"],
      "settings": {
        "title": "カテゴリーから探す",
        "image_ratio": "square",
        "columns_desktop": 3,
        "color_scheme": "scheme-1",
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "komorebi_usp": {
      "type": "komorebi-usp",
      "blocks": {
        "u1": { "type": "item", "settings": { "icon": "truck", "title": "¥10,000以上で送料無料", "subtext": "全国一律・対象外地域なし" } },
        "u2": { "type": "item", "settings": { "icon": "leaf", "title": "上質な天然素材", "subtext": "厳選した素材だけを使用" } },
        "u3": { "type": "item", "settings": { "icon": "return", "title": "30日間返品OK", "subtext": "安心してお試しください" } }
      },
      "block_order": ["u1", "u2", "u3"],
      "settings": { "color_scheme": "scheme-2", "padding_top": 28, "padding_bottom": 28 }
    },
    "feature": {
      "type": "image-with-text",
      "blocks": {
        "caption": { "type": "caption", "settings": { "caption": "FEATURE", "text_style": "caption-with-letter-spacing", "text_size": "medium" } },
        "heading": { "type": "heading", "settings": { "heading": "リネンという、心地よさ", "heading_size": "h1" } },
        "text": { "type": "text", "settings": { "text": "<p>通気性にすぐれ、使うほどにやわらかく肌になじむリネン。季節を問わず心地よく、一枚で日常を上質に整えます。<\/p>", "text_style": "body" } },
        "button": { "type": "button", "settings": { "button_label": "商品を見る", "button_link": "shopify://collections/all", "button_style_secondary": false } }
      },
      "block_order": ["caption", "heading", "text", "button"],
      "settings": {
        "image": "shopify://shop_images/komorebi-feature.jpg",
        "layout": "image_first",
        "color_scheme": "scheme-1",
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "komorebi_reviews": {
      "type": "komorebi-reviews",
      "blocks": {
        "rv1": { "type": "review", "settings": { "rating": 5, "quote": "肌ざわりがよく、毎日着たくなります。洗うほどに馴染むのも気に入っています。", "author": "東京都・30代 / A.K" } },
        "rv2": { "type": "review", "settings": { "rating": 5, "quote": "シンプルで上質。長く使える定番に出会えました。", "author": "大阪府・40代 / M.S" } },
        "rv3": { "type": "review", "settings": { "rating": 4, "quote": "素材が良く、合わせやすいです。また購入したいと思います。", "author": "福岡県・20代 / Y.T" } }
      },
      "block_order": ["rv1", "rv2", "rv3"],
      "settings": { "heading": "お客様の声", "color_scheme": "scheme-1", "padding_top": 64, "padding_bottom": 64 }
    }
  },
  "order": [
    "image_banner",
    "komorebi_usp",
    "featured_collection",
    "collection_list",
    "feature",
    "rich_text",
    "komorebi_promise",
    "komorebi_reviews"
  ]
}

{%- comment -%} Komorebi USP帯（自作）: 送料無料・素材・返品などの安心ポイント {%- endcomment -%}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width komorebi-usp" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    <div class="komorebi-usp__grid">
      {%- for block in section.blocks -%}
        <div class="komorebi-usp__item" {{ block.shopify_attributes }}>
          <span class="komorebi-usp__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 5h11v9H3z"/><path d="M14 8h3.5L21 11.5V14H14z"/><circle cx="6.5" cy="17.5" r="1.6"/><circle cx="17" cy="17.5" r="1.6"/></svg>
              {%- when 'leaf' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
              {%- when 'return' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11a9 9 0 1 1 .9 4"/><path d="M3 5v6h6"/></svg>
              {%- when 'gift' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="8" width="18" height="13" rx="1"/><path d="M3 12h18M12 8v13M12 8S10 3 7.5 4.2 9.5 8 12 8 14 3 16.5 4.2 14 8 12 8"/></svg>
            {%- endcase -%}
          </span>
          <div class="komorebi-usp__text">
            {%- if block.settings.title != blank -%}<p class="komorebi-usp__title">{{ block.settings.title | escape }}</p>{%- endif -%}
            {%- if block.settings.subtext != blank -%}<p class="komorebi-usp__sub">{{ block.settings.subtext | escape }}</p>{%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
.komorebi-usp__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
.komorebi-usp__item { display: flex; align-items: center; justify-content: center; gap: 1.2rem; }
.komorebi-usp__icon { display: inline-flex; width: 2.8rem; height: 2.8rem; flex: 0 0 auto; }
.komorebi-usp__icon svg { width: 100%; height: 100%; }
.komorebi-usp__title { margin: 0; font-weight: 600; }
.komorebi-usp__sub { margin: 0.2rem 0 0; font-size: 1.2rem; opacity: 0.7; }
@media screen and (max-width: 749px) { .komorebi-usp__grid { grid-template-columns: 1fr; gap: 1.4rem; } }
{% endstylesheet %}

{% schema %}
{
  "name": "USP帯",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "color_scheme", "id": "color_scheme", "label": "配色", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "上余白", "default": 28 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 80, "step": 4, "unit": "px", "label": "下余白", "default": 28 }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "項目",
      "settings": [
        { "type": "select", "id": "icon", "label": "アイコン", "default": "truck", "options": [
          { "value": "truck", "label": "配送（送料）" },
          { "value": "leaf", "label": "葉（素材）" },
          { "value": "return", "label": "返品（矢印）" },
          { "value": "gift", "label": "ギフト" }
        ] },
        { "type": "text", "id": "title", "label": "タイトル", "default": "タイトル" },
        { "type": "text", "id": "subtext", "label": "補足", "default": "補足テキスト" }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    { "name": "USP帯", "blocks": [ { "type": "item" }, { "type": "item" }, { "type": "item" } ] }
  ]
}
{% endschema %}

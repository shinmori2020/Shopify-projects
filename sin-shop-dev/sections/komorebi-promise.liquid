{%- comment -%} Komorebi「約束」セクション（自作）: インラインSVGアイコン＋左寄せテキスト {%- endcomment -%}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width komorebi-promise" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    {%- if section.settings.heading != blank -%}
      <h2 class="komorebi-promise__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    <div class="komorebi-promise__grid">
      {%- for block in section.blocks -%}
        <div class="komorebi-promise__item" {{ block.shopify_attributes }}>
          <span class="komorebi-promise__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'leaf' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
              {%- when 'scissors' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><line x1="20" y1="4" x2="8.12" y2="15.88"/><line x1="14.47" y1="14.48" x2="20" y2="20"/><line x1="8.12" y1="8.12" x2="12" y2="12"/></svg>
              {%- when 'hanger' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M12 7a2.2 2.2 0 1 1 2.2-2.2"/><path d="M12 7.2v1.6l8 5.3a1.3 1.3 0 0 1-.72 2.4H4.72A1.3 1.3 0 0 1 4 14.1l8-5.3"/></svg>
            {%- endcase -%}
          </span>
          {%- if block.settings.heading != blank -%}
            <h3 class="komorebi-promise__item-title">{{ block.settings.heading | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="komorebi-promise__item-text rte">{{ block.settings.text }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
.komorebi-promise__title { text-align: center; margin: 0 0 4rem; }
.komorebi-promise__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 4rem; }
.komorebi-promise__item { text-align: center; }
.komorebi-promise__icon { display: inline-flex; width: 4.4rem; height: 4.4rem; margin-bottom: 1.6rem; }
.komorebi-promise__icon svg { width: 100%; height: 100%; }
.komorebi-promise__item-title { margin: 0 0 0.8rem; font-size: 1.6rem; }
.komorebi-promise__item-text { text-align: left; line-height: 1.9; }
@media screen and (max-width: 749px) {
  .komorebi-promise__grid { grid-template-columns: 1fr; gap: 2.8rem; }
  .komorebi-promise__title { margin-bottom: 2.8rem; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Komorebiの約束",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "見出し", "default": "Komorebiの約束" },
    { "type": "color_scheme", "id": "color_scheme", "label": "配色", "default": "scheme-2" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "上余白", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "下余白", "default": 64 }
  ],
  "blocks": [
    {
      "type": "promise",
      "name": "約束",
      "settings": [
        { "type": "select", "id": "icon", "label": "アイコン", "default": "leaf", "options": [
          { "value": "leaf", "label": "葉（素材）" },
          { "value": "scissors", "label": "はさみ（ものづくり）" },
          { "value": "hanger", "label": "ハンガー（デザイン）" }
        ] },
        { "type": "text", "id": "heading", "label": "タイトル", "default": "タイトル" },
        { "type": "richtext", "id": "text", "label": "本文", "default": "<p>説明文</p>" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "Komorebiの約束", "blocks": [ { "type": "promise" }, { "type": "promise" }, { "type": "promise" } ] }
  ]
}
{% endschema %}

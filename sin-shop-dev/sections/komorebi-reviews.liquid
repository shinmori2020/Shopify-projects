{%- comment -%} Komorebi お客様の声（自作）: 星評価＋引用＋名前 {%- endcomment -%}
<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width komorebi-reviews" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
    {%- if section.settings.heading != blank -%}
      <h2 class="komorebi-reviews__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    <div class="komorebi-reviews__grid">
      {%- for block in section.blocks -%}
        <div class="komorebi-reviews__item" {{ block.shopify_attributes }}>
          <div class="komorebi-reviews__stars" aria-hidden="true">
            {%- for i in (1..5) -%}
              <svg viewBox="0 0 24 24" fill="currentColor" class="{% if forloop.index <= block.settings.rating %}is-on{% endif %}"><path d="M12 2l2.9 6.3 6.9.6-5.2 4.6 1.6 6.8L12 17.3 5.8 20.9l1.6-6.8L2.2 9.5l6.9-.6z"/></svg>
            {%- endfor -%}
          </div>
          {%- if block.settings.quote != blank -%}
            <blockquote class="komorebi-reviews__quote">{{ block.settings.quote | escape }}</blockquote>
          {%- endif -%}
          {%- if block.settings.author != blank -%}
            <p class="komorebi-reviews__author">{{ block.settings.author | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
.komorebi-reviews__title { text-align: center; margin: 0 0 4rem; }
.komorebi-reviews__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3.2rem; }
.komorebi-reviews__item { text-align: center; }
.komorebi-reviews__stars { display: inline-flex; gap: 0.2rem; margin-bottom: 1.2rem; }
.komorebi-reviews__stars svg { width: 1.8rem; height: 1.8rem; opacity: 0.25; }
.komorebi-reviews__stars svg.is-on { opacity: 1; color: #d99a2b; }
.komorebi-reviews__quote { margin: 0 0 1.2rem; line-height: 1.9; }
.komorebi-reviews__author { margin: 0; font-weight: 600; font-size: 1.3rem; }
@media screen and (max-width: 749px) { .komorebi-reviews__grid { grid-template-columns: 1fr; gap: 2.6rem; } }
{% endstylesheet %}

{% schema %}
{
  "name": "お客様の声",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "見出し", "default": "お客様の声" },
    { "type": "color_scheme", "id": "color_scheme", "label": "配色", "default": "scheme-1" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "上余白", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "label": "下余白", "default": 64 }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "レビュー",
      "settings": [
        { "type": "range", "id": "rating", "min": 1, "max": 5, "step": 1, "label": "星の数", "default": 5 },
        { "type": "text", "id": "quote", "label": "コメント", "default": "とても気に入っています。" },
        { "type": "text", "id": "author", "label": "お名前", "default": "お客様" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    { "name": "お客様の声", "blocks": [ { "type": "review" }, { "type": "review" }, { "type": "review" } ] }
  ]
}
{% endschema %}
